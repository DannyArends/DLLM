{
	"name": "dllm",
	"targetName": "DLLM",
	"description": "An example of calling llama.cpp from D.",
	"authors": ["Danny Arends"],
	"homepage": "http://www.dannyarends.nl",
	"copyright": "Copyright © 2025, Danny Arends",
	"license": "GPL-v3",
	"configurations": [
	{
		"name": "default",
		"mainSourceFile": "src/main.d",
		"targetType": "executable",
		"targetPath": "bin",
		"platforms": ["linux", "windows"],
		"dflags": ["-P-I./deps/llama.cpp/include/", "-P-I./deps/llama.cpp/ggml/include/", "-P-I./deps/llama.cpp/tools/mtmd/"],
		"sourceFiles-linux": [
			"./deps/llama.cpp/build/src/libllama.a",
			"./deps/llama.cpp/build/ggml/src/libggml.a",
			"./deps/llama.cpp/build/ggml/src/libggml-base.a",
			"./deps/llama.cpp/build/ggml/src/libggml-cpu.a",
			"./deps/llama.cpp/build/ggml/src/ggml-cuda/libggml-cuda.a",
			"./deps/llama.cpp/build/tools/mtmd/libmtmd.a"],
		"lflags-linux": [
				"-L/usr/local/cuda/lib64", 
				"-L-static-libstdc++", "-L-static-libgcc", "-L-static", "-l:libgomp.a",
				"-L-dynamic", "-lpthread", "-ldl"],
		"libs-linux": ["stdc++", "cuda", "cudart", "cublas", "culibos"],
		"libs-windows-x86_64": ["llama", "mtmd", "ggml", "ggml-base", "ggml-cpu"],
		"lflags-windows-x86_64": [
			"/LIBPATH:./deps/llama.cpp/build/src/Release",
			"/LIBPATH:./deps/llama.cpp/build/tools/mtmd/Release",
			"/LIBPATH:./deps/llama.cpp/build/ggml/src/Release"],
		"copyFiles-windows-x86_64": [
			"./deps/llama.cpp/build/bin/Release/llama.dll",
			"./deps/llama.cpp/build/bin/Release/ggml.dll",
			"./deps/llama.cpp/build/bin/Release/ggml-base.dll",
			"./deps/llama.cpp/build/bin/Release/ggml-cpu.dll",
			"./deps/llama.cpp/build/bin/Release/ggml-cuda.dll",
			"./deps/llama.cpp/build/bin/Release/mtmd.dll"]
	}]
}

